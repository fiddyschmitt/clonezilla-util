<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- TEMP: local feed for the patched SharpCompress (0.49.1-localbzip2patch), which adds the BZip2
         tolerateTruncatedStream option for seekable bzip2. Remove this source (and switch the
         SharpCompress PackageReference back to the official version) once the upstream PR ships.
         This merges with the global NuGet config, so nuget.org still works. -->
    <add key="local-bzip2patch" value="..\local-nuget" />
  </packageSources>
</configuration>
