<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local feed for locally-packed packages not yet on nuget.org: XzSeekable and ZstdSeekable
         (see libClonezilla.csproj). SharpCompress no longer comes from here - the bzip2
         tolerateTruncatedStream patch shipped upstream in 0.50.0 (our PR #1358).
         This merges with the global NuGet config, so nuget.org still works. -->
    <add key="local-packages" value="..\local-nuget" />
  </packageSources>
</configuration>
